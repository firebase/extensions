{
  "name": "@firebaseextensions/fs-bq-import-collection",
  "version": "0.1.27",
  "description": "Import a Firestore Collection into a BigQuery Changelog Table",
  "main": "./lib/index.js",
  "repository": {
    "type": "git",
    "url": "github.com/firebase/extensions.git",
    "directory": "firestore-bigquery-export/scripts/import"
  },
  "scripts": {
    "build": "npm run clean && npm run compile",
    "build-watch": "npm run clean && tsc --watch",
    "clean": "rimraf ./lib",
    "compile": "tsc",
    "import": "node ./lib/index.js",
    "prepare": "npm run build",
    "test:local": "jest --testPathIgnorePatterns=e2e.test.ts --forceExit",
    "test:all": "jest",
    "test:e2e": "jest e2e.test.ts"
  },
  "files": [
    "lib"
  ],
  "bin": {
    "fs-bq-import-collection": "./lib/index.js"
  },
  "author": "Jan Wyszynski <wyszynski@google.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "@firebaseextensions/firestore-bigquery-change-tracker": "^2.0.2",
    "@google-cloud/bigquery": "^5.6.0",
    "commander": "5.1.0",
    "filenamify": "^4.2.0",
    "firebase-admin": "^13.0.0",
    "generate-schema": "^2.6.0",
    "inquirer": "^13.4.1",
    "sql-formatter": "^2.3.3",
    "workerpool": "^6.1.4"
  },
  "devDependencies": {
    "@types/chai": "^4.2.0",
    "@types/jest": "29.5.0",
    "@types/workerpool": "^6.0.0",
    "chai": "^4.2.0",
    "dotenv": "^16.3.1",
    "jest": "29.7.0",
    "nanoid": "^5.0.9",
    "rimraf": "^2.6.3",
    "ts-jest": "29.4.9",
    "typescript": "^4.9.5"
  }
}
